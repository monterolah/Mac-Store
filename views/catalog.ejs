<%- include('partials/header', {title:'Catálogo', description:'Todos los productos Apple disponibles'}) %>
<style>
  .catalog-page {
    padding: 44px 22px 80px;
  }
  .catalog-grid {
    display: grid !important;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)) !important;
    gap: 20px !important;
  }
  @media (max-width: 900px) {
    .catalog-page {
      padding: 32px 16px 64px;
    }
    .catalog-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
      gap: 14px !important;
    }
  }
  @media (max-width: 640px) {
    .catalog-page {
      padding: 24px 14px 56px;
    }
    .catalog-grid {
      grid-template-columns: 1fr !important;
      gap: 12px !important;
    }
    .catalog-filter-row {
      justify-content: flex-start !important;
      gap: 6px !important;
      margin-bottom: 24px !important;
    }
    .catalog-filter-row a {
      font-size: 13px;
      padding: 8px 14px !important;
    }
  }
</style>
<div class="catalog-page" style="padding:44px 22px 80px">
  <div style="max-width:1024px;margin:0 auto">
    <div style="text-align:center;margin-bottom:40px">
      <h2 style="font-size:clamp(28px,4vw,48px);font-weight:700;letter-spacing:-.045em;margin-bottom:8px">Catálogo completo</h2>
      <p style="font-size:17px;color:#86868b">Todo el ecosistema Apple</p>
    </div>
    <div class="catalog-filter-row" style="display:flex;gap:8px;flex-wrap:wrap;justify-content:center;margin-bottom:36px">
      <a href="/productos" style="background:#1d1d1f;color:#fff;padding:9px 20px;border-radius:980px;font-size:14px;font-weight:500">Todo</a>
      <% (categories||[]).forEach(c=>{ %>
        <a href="/categoria/<%=c.slug%>" style="background:transparent;color:#0071e3;border:1px solid #0071e3;padding:8px 18px;border-radius:980px;font-size:14px;transition:all .2s" onmouseover="this.style.background='#0071e3';this.style.color='#fff'" onmouseout="this.style.background='transparent';this.style.color='#0071e3'"><%=c.name%></a>
      <% }) %>
    </div>
    <div class="catalog-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:28px 20px">
      <% (products||[]).forEach(p=>{ %>
      <%
        const firstCatalogColor = (p.color_variants&&p.color_variants.length)?p.color_variants[0]:null;
        const enabledCatalogColors = (p.color_variants||[]).filter(c=>c && c.enabled !== false);
        const firstCatalogVariant = (p.variants||[]).find(v=>v&&v.label);
        const srcCatalog = firstCatalogColor&&firstCatalogColor.image_url ? firstCatalogColor.image_url : (p.image_url||'');
        const isVMCatalog = String(srcCatalog).match(/\.(mp4|webm|ogg|mov)$/i);
        const waTextCatalog = 'Hola%2C%20quiero%20comprar%20' + encodeURIComponent(p.name) + (firstCatalogVariant?' '+encodeURIComponent(firstCatalogVariant.label):'') + '%20(' + encodeURIComponent(formatPrice(firstCatalogVariant&&firstCatalogVariant.price?firstCatalogVariant.price:p.price)) + ')';
      %>
      <div class="ms-card" style="display:flex;flex-direction:column;padding:0;overflow:hidden">
        <a href="/producto/<%=p.slug%>" style="text-decoration:none;color:inherit;display:block;background:#fff">
          <div class="ms-card-img" style="--img-scale:<%=firstCatalogColor&&firstCatalogColor.img_scale ? firstCatalogColor.img_scale : (p.img_scale||1)%>;margin-bottom:0;background:#fff">
            <% if(p.badge){ %><span class="ms-card-badge"><%=p.badge%></span><% } %>
            <div class="ms-card-glow"></div>
            <% if(isVMCatalog) { %>
              <video src="<%=srcCatalog%>" autoplay loop muted playsinline style="max-height:220px;width:100%;object-fit:contain;"></video>
            <% } else { %>
              <img src="<%=srcCatalog%>" alt="<%=p.name%>" loading="lazy" style="object-fit:<%=firstCatalogColor&&firstCatalogColor.img_fit ? firstCatalogColor.img_fit : (p.img_fit||'contain')%>;object-position:<%=firstCatalogColor&&firstCatalogColor.img_pos ? firstCatalogColor.img_pos : (p.img_pos||'center')%>;transform:scale(<%=firstCatalogColor&&firstCatalogColor.img_scale ? firstCatalogColor.img_scale : (p.img_scale||1)%>);transform-origin:center center" onerror="this.style.display='none'">
            <% } %>
          </div>
        </a>
        <div style="background:#f5f5f7;padding:14px 16px 16px;flex:1;display:flex;flex-direction:column">
          <a href="/producto/<%=p.slug%>" style="text-decoration:none;color:inherit">
            <h3 style="font-size:16px;font-weight:600;letter-spacing:-.025em;line-height:1.2;margin-bottom:4px;color:#1d1d1f"><%=p.name%></h3>
            <% if(firstCatalogVariant){ %><p style="font-size:14px;color:#515154;margin-bottom:8px"><%=firstCatalogVariant.label%></p><% } %>
          </a>
          <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;margin-bottom:12px">
            <div>
              <% if(p.original_price){ %><span style="font-size:13px;color:#86868b;text-decoration:line-through;margin-right:5px"><%=formatPrice(p.original_price)%></span><% } %><span style="font-size:17px;font-weight:700;color:#1d1d1f"><%=formatPrice(p.price)%></span>
            </div>
            <% if(enabledCatalogColors.length){ %>
            <div style="display:flex;gap:5px;flex-wrap:wrap;justify-content:flex-end" onclick="event.preventDefault()">
              <% enabledCatalogColors.slice(0,4).forEach((c,ci)=>{ const sw=c.swatch_url||c.image_url||''; if(sw){ %>
              <span class="ms-card-swatch <%=ci===0?'active':''%>"
                style="width:18px;height:18px;background-image:url('<%=sw%>')"
                title="<%=c.name||''%>"
                data-img="<%=c.image_url||''%>"
                data-scale="<%=c.img_scale||p.img_scale||1%>"
                data-fit="<%=c.img_fit||p.img_fit||'contain'%>"
                data-pos="<%=c.img_pos||p.img_pos||'center'%>"
                onclick="cardSwatchClick(this,event)"></span>
              <% } }) %>
              <% if(enabledCatalogColors.length>4){ %><span class="ms-card-swatch-more" style="width:18px;height:18px;font-size:9px">+<%=enabledCatalogColors.length-4%></span><% } %>
            </div>
            <% } %>
          </div>
          <% if(settings&&settings.store_whatsapp){ %>
          <a href="https://wa.me/<%=settings.store_whatsapp%>?text=<%=waTextCatalog%>" target="_blank"
             style="display:block;width:100%;text-align:center;background:#0071e3;color:#fff;padding:11px 0;border-radius:980px;font-size:15px;font-weight:600;text-decoration:none;transition:background .2s;box-sizing:border-box"
             onmouseover="this.style.background='#0077ed'" onmouseout="this.style.background='#0071e3'">Comprar</a>
          <% } else { %>
          <a href="/producto/<%=p.slug%>"
             style="display:block;width:100%;text-align:center;background:#0071e3;color:#fff;padding:11px 0;border-radius:980px;font-size:15px;font-weight:600;text-decoration:none;transition:background .2s;box-sizing:border-box"
             onmouseover="this.style.background='#0077ed'" onmouseout="this.style.background='#0071e3'">Comprar</a>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
