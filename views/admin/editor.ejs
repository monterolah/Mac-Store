          content:'<div style="padding:24px;overflow-x:auto"><table style="width:100%;border-collapse:collapse;font-size:14px"><thead><tr style="background:#1d1d1f;color:#fff"><th style="padding:12px 16px;text-align:left">Modelo</th><th style="padding:12px 16px">Almacenamiento</th><th style="padding:12px 16px">Precio</th></tr></thead><tbody><tr style="border-bottom:1px solid #e5e5e7"><td style="padding:12px 16px">iPhone 16</td><td style="padding:12px 16px;text-align:center">128 GB</td><td style="padding:12px 16px;text-align:center">$799</td></tr><tr style="border-bottom:1px solid #e5e5e7;background:#f9f9f9"><td style="padding:12px 16px">iPhone 16 Pro</td><td style="padding:12px 16px;text-align:center">256 GB</td><td style="padding:12px 16px;text-align:center">$999</td></tr><tr><td style="padding:12px 16px">iPhone 16 Pro Max</td><td style="padding:12px 16px;text-align:center">512 GB</td><td style="padding:12px 16px;text-align:center">$1199</td></tr></tbody></table></div>' },
      ]
    },
    layerManager: { appendTo: '#lm-wrap' },
    traitManager: { appendTo: '#tm-wrap' },
    panels: { defaults: [] },
  });

  // Inyectar CSS extra en el iframe del canvas para mejor edición
  ed.once('load', () => {
    try {
      const doc = ed.Canvas.getDocument();
      if (!doc) return;
      const s = doc.createElement('style');
      s.textContent = [
        '* { box-sizing: border-box; }',
        // Indicador visual al hovear para saber que el elemento es editable
        '[data-gjs-type]:not([data-gjs-type="wrapper"]):hover { outline: 1px dashed rgba(0,113,227,.35) !important; outline-offset: 2px !important; }',
      ].join('\n');
      doc.head.appendChild(s);
    } catch(e) { /* iframe aún no listo */ }
  });

  setupEditorBehaviors();
}

// ── Comportamientos del canvas ────────────────────────────────────────────
function setupEditorBehaviors() {
  if (!ed) return;

  // Habilitar resize en todos los componentes YA cargados
  ed.getWrapper()?.onAll(comp => {
    if (!comp.get('resizable')) {
      comp.set({ resizable: { handles: 'all', step: 1, minDim: 8 } });
    }
    _patchToolbar(comp);
  });

  // Habilitar resize + toolbar en componentes NUEVOS al agregarlos
  ed.on('component:add', comp => {
    comp.set({ resizable: { handles: 'all', step: 1, minDim: 8 } });
    _patchToolbar(comp);
  });

  // Info del componente seleccionado en el panel derecho
  ed.on('component:selected', comp => {
    const tag = comp.get('tagName') || comp.get('type') || 'div';
    const cls = (comp.getClasses() || []).filter(Boolean).slice(0, 3);
    const clsStr = cls.length ? ' .' + cls.join(' .') : '';
    const el = document.getElementById('comp-info');
    if (el) el.innerHTML = `<span style="color:#86868b">&lt;</span><span style="color:#56c0f2">${tag}</span><span style="color:#a8d8a8">${clsStr}</span><span style="color:#86868b">&gt;</span>`;
    showPanel('style');
  });
  ed.on('component:deselected', () => {
    const el = document.getElementById('comp-info');
    if (el) el.innerHTML = '<span style="color:#555">Selecciona un elemento para editar</span>';
  });

  // Comandos personalizados para este editor
  if (!ed.Commands.has('ms:move-up')) {
    ed.Commands.add('ms:move-up', {
      run(editor) {
        const c = editor.getSelected(); if (!c?.parent()) return;
        const p = c.parent(), i = p.indexOf(c);
        if (i > 0) { p.move(c, { at: i - 1 }); editor.select(c); }
      }
    });
  }
  if (!ed.Commands.has('ms:move-down')) {
    ed.Commands.add('ms:move-down', {
      run(editor) {
        const c = editor.getSelected(); if (!c?.parent()) return;
        const p = c.parent(), i = p.indexOf(c);
        if (i < p.components().length - 1) { p.move(c, { at: i + 2 }); editor.select(c); }
      }
    });
  }
  if (!ed.Commands.has('ms:duplicate')) {
    ed.Commands.add('ms:duplicate', {
      run(editor) {
        const c = editor.getSelected(); if (!c?.parent()) return;
        const p = c.parent(), clone = c.clone();
        p.append(clone, { at: p.indexOf(c) + 1 });
        editor.select(clone);
        toast('Duplicado ✓', 'ok');
      }
    });
  }
}

// Agrega botones Mover↑ Mover↓ Duplicar a la toolbar flotante del componente
function _patchToolbar(comp) {
  const tb = comp.get('toolbar') || [];
  if (tb.find(t => t.id === 'ms-up')) return; // ya tiene los botones
  comp.set('toolbar', [
    { id:'ms-up',
      label:'<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="18 15 12 9 6 15"/></svg>',
      attributes:{ title:'Mover arriba' }, command:'ms:move-up' },
    { id:'ms-down',
      label:'<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6 9 12 15 18 9"/></svg>',
      attributes:{ title:'Mover abajo' }, command:'ms:move-down' },
    { id:'ms-dup',
      label:'<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>',
      attributes:{ title:'Duplicar' }, command:'ms:duplicate' },
    ...tb,
  ]);
}

// ── Load page ─────────────────────────────────────────────────────────────
function bodyFromHtml(html) {
  if (!html) return '';
  const m = String(html).match(/<body[^>]*>([\s\S]*)<\/body>/i);
  return (m ? m[1] : String(html)).trim();
}

async function loadPage(pageName) {
  curPage = pageName;
  const ld  = document.getElementById('ed-loading');
  const msg = document.getElementById('ed-msg');
  ld.style.display = 'flex';
  msg.textContent = 'Cargando...';

  try {
    const dRes = await fetch('/api/editor/design?page=' + pageName, { headers:{ Authorization:'Bearer '+TOKEN } });
    const saved = dRes.ok ? await dRes.json() : null;

    if (saved && saved.html && saved.html.trim()) {
      // Usar el HTML guardado (ya fue re-renderizado con datos frescos tras cada cambio del admin)
      initEditor(bodyFromHtml(saved.html), saved.css || '');
      return;
    }

    // Sin diseño guardado: renderizar fresco desde EJS
    msg.textContent = 'Renderizando...';
    const rRes = await fetch('/api/editor/render?page=' + pageName, { headers:{ Authorization:'Bearer '+TOKEN } });
    if (!rRes.ok) throw new Error('Error al renderizar: ' + rRes.status);
    const html = await rRes.text();
    initEditor(bodyFromHtml(html), saved?.css || '');
  } catch(e) {
    console.error(e);
    toast('Error al cargar: ' + e.message, 'err');
    initEditor('<div style="padding:40px;text-align:center;color:#c00">Error: ' + e.message + '</div>', '');
  } finally {
    ld.style.display = 'none';
  }
}

// ── URL pública para cada página ──────────────────────────────────────────
function publicUrl(pageName) {
  if (!pageName || pageName === 'home')    return '/';
  if (pageName === 'catalog')              return '/productos';
  if (pageName.startsWith('category-'))   return '/categoria/' + pageName.slice(9);
  if (pageName.startsWith('product-'))    return '/producto/'  + pageName.slice(8);
  return '/';
}

let _storeTab = null;

function openInStore() {
  const url = publicUrl(curPage) + '?t=' + Date.now();
  if (_storeTab && !_storeTab.closed) { _storeTab.location.replace(url); _storeTab.focus(); }
  else { _storeTab = window.open(url, 'macstore_preview'); }
}

// ── Save ──────────────────────────────────────────────────────────────────
// Extrae inline styles de elementos con clases del template y los convierte a CSS
function inlineStylesAsCss(html) {
  try {
    const tmp = document.createElement('div');
    tmp.innerHTML = html;
    let extra = '';
    tmp.querySelectorAll('[style]').forEach(el => {
      const style = el.getAttribute('style');
      if (!style) return;
      // Solo usa clases que no sean de GrapesJS (gjs-, selected, etc.)
      const classes = Array.from(el.classList)
        .filter(c => c && !c.startsWith('gjs') && c !== 'selected' && c.length > 1);
      if (!classes.length) return;
      const selector = classes.map(c => '.' + CSS.escape(c)).join('');
      extra += `${selector} { ${style} }\n`;
    });
    return extra;
  } catch { return ''; }
}

async function saveDesign() {
  if (!ed) return;
  const btn = document.getElementById('btn-save');
  btn.disabled = true; btn.textContent = 'Guardando...';
  try {
    const bodyHtml  = ed.getHtml();
    const inlineCss = inlineStylesAsCss(bodyHtml);
    const css       = ed.getCss() + (inlineCss ? '\n/* inline overrides */\n' + inlineCss : '');
    const gjsData  = JSON.stringify(ed.getProjectData());
    const fullHtml = `<!DOCTYPE html>\n<html lang="es">\n<head>\n<meta charset="UTF-8">\n<meta name="viewport" content="width=device-width,initial-scale=1">\n<title>${SETTINGS.store_name||'MacStore'}</title>\n<link rel="stylesheet" href="/css/macstore.css">\n<style>${css}</style>\n</head>\n<body>${bodyHtml}</body>\n</html>`;
    const res = await fetch('/api/editor/save', {
      method:'POST',
      headers:{'Content-Type':'application/json','Authorization':'Bearer '+TOKEN},
      body: JSON.stringify({ page:curPage, html:fullHtml, css, gjsData })
    });
    if (!res.ok) throw new Error((await res.json()).error || 'Error');
    toast('Guardado ✓', 'ok');
    if (_storeTab && !_storeTab.closed) { _storeTab.location.replace(publicUrl(curPage) + '?t=' + Date.now()); }
  } catch(e) {
    toast('Error: ' + e.message, 'err');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Guardar';
  }
}

// ── Publicar en GoDaddy ───────────────────────────────────────────────────
async function deployToGodaddy() {
  const btn = document.getElementById('btn-deploy');
  btn.disabled = true; btn.textContent = 'Publicando...';
  toast('Iniciando publicación en GoDaddy...', 'ok');
  try {
    const es = new EventSource('/api/deploy');
    es.onmessage = (e) => {
      const d = JSON.parse(e.data);
      if (d.type === 'step')     toast(d.msg, 'ok');
      if (d.type === 'progress') btn.textContent = `Subiendo ${d.uploaded}/${d.total}...`;
      if (d.type === 'done') {
        es.close();
        toast(`✓ Publicado — ${d.uploaded} archivo(s) subidos, ${d.skipped} sin cambios`, 'ok');
        btn.disabled = false;
        btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg> Publicar GoDaddy';
      }
      if (d.type === 'error') {
        es.close();
        toast('Error: ' + d.msg, 'err');
        btn.disabled = false;
        btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg> Publicar GoDaddy';
      }
    };
    es.onerror = () => { es.close(); toast('Error de conexión con el servidor', 'err'); btn.disabled = false; };
  } catch(e) {
    toast('Error: ' + e.message, 'err');
    btn.disabled = false;
  }
}

// ── Guardar todo ──────────────────────────────────────────────────────────
async function saveAll() {
  const btn = document.getElementById('btn-save-all');
  btn.disabled = true; btn.textContent = 'Guardando...';
  try {
    // Primero guardar la página actual con el estado de GrapesJS
    await saveDesign();
    // Luego renderizar y guardar todas las páginas en el servidor
    const res = await fetch('/api/editor/save-all', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + TOKEN },
      body: JSON.stringify({})
    });
    if (!res.ok) throw new Error((await res.json()).error || 'Error');
    const data = await res.json();
    const n = data.saved?.length || 0;
    toast(`Todo guardado ✓ — ${n} página${n !== 1 ? 's' : ''} actualizadas`, 'ok');
    if (_storeTab && !_storeTab.closed) _storeTab.location.reload();
  } catch(e) {
    toast('Error: ' + e.message, 'err');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Guardar todo';
  }
}

// ── Recargar contenido actual de la tienda en el canvas ───────────────────
// NO borra cambios guardados, solo actualiza el canvas con las categorías,
// productos y logo más recientes del admin.
async function reloadContent() {
  const btn = document.getElementById('btn-reload');
  btn.disabled = true;
  toast('Recargando contenido de la tienda...', 'ok');
  try {
    const rRes = await fetch('/api/editor/render?page=' + curPage, { headers:{ Authorization:'Bearer '+TOKEN } });
    if (!rRes.ok) throw new Error('Error al renderizar: ' + rRes.status);
    const html = await rRes.text();
    // Mantener el CSS actual si hay
    const dRes = await fetch('/api/editor/design?page=' + curPage, { headers:{ Authorization:'Bearer '+TOKEN } });
    const saved = dRes.ok ? await dRes.json() : null;
    initEditor(bodyFromHtml(html), saved?.css || '');
    toast('Contenido recargado ✓ — recordá guardar cuando termines', 'ok');
  } catch(e) {
    toast('Error: ' + e.message, 'err');
  } finally {
    btn.disabled = false;
  }
}

// ── Devices ───────────────────────────────────────────────────────────────
function setDev(name) {
  if (!ed) return;
  ed.setDevice({desktop:'Desktop',tablet:'Tablet',mobile:'Mobile'}[name]);
  document.querySelectorAll('.dev-btn').forEach(b=>b.classList.remove('on'));
  document.getElementById('d-'+name)?.classList.add('on');
}

// ── Preview ───────────────────────────────────────────────────────────────
function togglePreview() {
  if (!ed) return;
  prevMode = !prevMode;
  prevMode ? ed.runCommand('preview') : ed.stopCommand('preview');
  document.getElementById('btn-prev').style.color = prevMode ? '#0071e3' : '';
}

// ── Duplicar ──────────────────────────────────────────────────────────────
function dupSelected() {
  if (!ed) return;
  const c = ed.getSelected();
  if (!c || !c.parent()) { toast('Selecciona algo primero', 'err'); return; }
  const p = c.parent(), clone = c.clone();
  p.append(clone, { at: p.indexOf(c) + 1 });
  ed.select(clone);
  toast('Duplicado ✓', 'ok');
}

// ── Delete ────────────────────────────────────────────────────────────────
function delSelected() {
  if (!ed) return;
  const sel = ed.getSelectedAll();
  if (!sel.length) { toast('Selecciona algo primero', 'err'); return; }
  sel.forEach(c => c.remove());
  toast('Eliminado', 'ok');
}

// ── Absolute drag mode ────────────────────────────────────────────────────
let _absMode = false;
function toggleAbsMode() {
  _absMode = !_absMode;
  const badge = document.getElementById('abs-badge');
  const btn   = document.getElementById('btn-abs');
  if (_absMode) {
    badge.classList.add('on');
    btn.style.color = '#ff9f0a';
    ed?.setDragMode('absolute');
    toast('Modo libre activado — arrastra los bloques a cualquier posición', 'ok');
  } else {
    badge.classList.remove('on');
    btn.style.color = '';
    ed?.setDragMode('translate');
    toast('Modo libre desactivado', 'ok');
  }
}

// ── Code Editor ───────────────────────────────────────────────────────────
let _codeTab = 'html';

function openCodeEditor() {
  if (!ed) return;
  _codeTab = 'html';
  document.getElementById('ctab-html').classList.add('on');
  document.getElementById('ctab-css').classList.remove('on');
  document.getElementById('code-ta').value = ed.getHtml();
  document.getElementById('code-hint').textContent = 'Edita el HTML del cuerpo de la página';
  document.getElementById('code-modal').classList.add('open');
  setTimeout(() => document.getElementById('code-ta').focus(), 80);
}

function closeCodeEditor() {
  document.getElementById('code-modal').classList.remove('open');
}

function switchCodeTab(tab) {
  _codeTab = tab;
  document.getElementById('ctab-html').classList.toggle('on', tab === 'html');
  document.getElementById('ctab-css').classList.toggle('on',  tab === 'css');
  if (tab === 'html') {
    document.getElementById('code-ta').value = ed ? ed.getHtml() : '';
    document.getElementById('code-hint').textContent = 'Edita el HTML del cuerpo de la página';
  } else {
    document.getElementById('code-ta').value = ed ? ed.getCss() : '';
    document.getElementById('code-hint').textContent = 'Edita el CSS personalizado';
  }
}

function applyCode() {
  if (!ed) return;
  const val = document.getElementById('code-ta').value;
  if (_codeTab === 'html') {
    ed.setComponents(val);
    setupEditorBehaviors();
    toast('HTML aplicado ✓', 'ok');
  } else {
    ed.setStyle(val);
    toast('CSS aplicado ✓', 'ok');
  }
  closeCodeEditor();
}

// Cerrar modal con Escape
document.addEventListener('keydown', e => {
  if (e.key === 'Escape' && document.getElementById('code-modal').classList.contains('open')) {
    closeCodeEditor();
  }
});

// ── Toast ─────────────────────────────────────────────────────────────────
let _tt = null;
function toast(msg, type='ok') {
  const el = document.getElementById('toast');
  el.textContent = msg; el.className = 'show ' + type;
  clearTimeout(_tt); _tt = setTimeout(()=>el.className='',3000);
}

// ── Keyboard shortcuts ────────────────────────────────────────────────────
document.addEventListener('keydown', e => {
  // No disparar si el foco está en un input/textarea
  const tag = document.activeElement?.tagName?.toLowerCase();
  const inInput = tag === 'input' || tag === 'textarea' || tag === 'select'
                  || document.activeElement?.isContentEditable;

  if ((e.metaKey||e.ctrlKey) && e.key==='s') { e.preventDefault(); saveDesign(); return; }
  if ((e.metaKey||e.ctrlKey) && e.key==='z' && !e.shiftKey) { e.preventDefault(); ed?.UndoManager?.undo(); return; }
  if ((e.metaKey||e.ctrlKey) && (e.key==='y'||e.key==='Z'))  { e.preventDefault(); ed?.UndoManager?.redo(); return; }
  if ((e.metaKey||e.ctrlKey) && e.key==='d') { e.preventDefault(); dupSelected(); return; }

  if (!inInput) {
    // Supr / Backspace → eliminar seleccionado (sin confirm si es 1 elemento)
    if (e.key==='Delete'||e.key==='Backspace') {
      if (!ed) return;
      const sel = ed.getSelectedAll();
      if (!sel.length) return;
      e.preventDefault();
      sel.forEach(c => c.remove());
      toast('Eliminado', 'ok');
    }
    // Flecha arriba/abajo → reordenar
    if (e.key==='ArrowUp'   && !e.metaKey && !e.ctrlKey) { e.preventDefault(); ed?.runCommand('ms:move-up'); }
    if (e.key==='ArrowDown' && !e.metaKey && !e.ctrlKey) { e.preventDefault(); ed?.runCommand('ms:move-down'); }
  }
});

window.onbeforeunload = () => ed ? '' : null;

// ── CSS Global ────────────────────────────────────────────────────────────
async function openGlobalCss() {
  try {
    const res  = await fetch('/api/editor/global-css', { headers:{ Authorization:'Bearer '+TOKEN } });
    const data = await res.json();
    document.getElementById('gcss-ta').value = data.css || '';
  } catch(e) { /* continuar vacío */ }
  document.getElementById('global-css-modal').classList.add('open');
  setTimeout(() => document.getElementById('gcss-ta').focus(), 80);
}

function closeGlobalCss() {
  document.getElementById('global-css-modal').classList.remove('open');
}

async function saveGlobalCss() {
  const css = document.getElementById('gcss-ta').value;
  const btn = document.getElementById('btn-save-gcss');
  btn.disabled = true; btn.textContent = 'Aplicando...';
  try {
    const res = await fetch('/api/editor/global-css', {
      method: 'POST',
      headers: { 'Content-Type':'application/json', 'Authorization':'Bearer '+TOKEN },
      body: JSON.stringify({ css })
    });
    if (!res.ok) throw new Error((await res.json()).error || 'Error');
    closeGlobalCss();
    toast('CSS Global aplicado a todas las páginas ✓', 'ok');
  } catch(e) {
    toast('Error: ' + e.message, 'err');
  } finally {
    btn.disabled = false; btn.textContent = 'Aplicar a todas las páginas ✓';
  }
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape' && document.getElementById('global-css-modal').classList.contains('open')) {
    closeGlobalCss();
  }
});

// ── Start ─────────────────────────────────────────────────────────────────
loadPage('home');
