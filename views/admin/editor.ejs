<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Editor — MacStore</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/grapesjs@0.21.13/dist/css/grapes.min.css">
<style>
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#1a1a1a}

/* ── TOP BAR ─────────────────────────────────── */
#ed-bar{
  position:fixed;top:0;left:0;right:0;height:50px;
  background:#1d1d1f;border-bottom:1px solid #333;
  display:flex;align-items:center;gap:8px;padding:0 14px;z-index:9999;
}
#ed-bar a.back{color:#86868b;text-decoration:none;font-size:13px;display:flex;align-items:center;gap:4px;flex-shrink:0}
#ed-bar a.back:hover{color:#fff}
.sep{width:1px;height:26px;background:#444;flex-shrink:0}
#ed-bar select{
  background:#2c2c2e;color:#fff;border:1px solid #444;
  border-radius:7px;padding:5px 8px;font-size:13px;cursor:pointer;outline:none;
}
.spacer{flex:1}
.dev-grp{display:flex;gap:2px;background:#2c2c2e;border-radius:7px;padding:2px}
.dev-btn{background:none;border:none;color:#86868b;cursor:pointer;padding:5px 7px;border-radius:5px;transition:.15s;line-height:1}
.dev-btn.on,.dev-btn:hover{background:#444;color:#fff}
.tbtn{
  display:flex;align-items:center;gap:5px;border:none;border-radius:7px;
  padding:6px 12px;font-size:13px;font-weight:600;cursor:pointer;transition:.15s;flex-shrink:0;
}
.tbtn-ghost{background:#2c2c2e;color:#ccc}.tbtn-ghost:hover{background:#3a3a3c;color:#fff}
.tbtn-green{background:#28a745;color:#fff}.tbtn-green:hover{background:#218838}
.tbtn:disabled{opacity:.5;cursor:not-allowed}

/* ── MAIN LAYOUT ─────────────────────────────── */
#ed-main{
  position:fixed;top:50px;left:0;right:0;bottom:0;
  display:flex;overflow:hidden;
}

/* Left sidebar */
#ed-left{
  width:50px;background:#1d1d1f;border-right:1px solid #333;
  display:flex;flex-direction:column;align-items:center;
  padding:8px 0;gap:4px;flex-shrink:0;
}
.ltool{
  width:38px;height:38px;display:flex;align-items:center;justify-content:center;
  background:none;border:none;color:#86868b;cursor:pointer;border-radius:8px;transition:.15s;
  font-size:17px;position:relative;
}
.ltool:hover,.ltool.on{background:#2c2c2e;color:#fff}
.ltool-del svg{stroke:#ff6b6b}
.ltool-del:hover{background:#3a1a1a!important}
.tip{
  position:absolute;left:46px;top:50%;transform:translateY(-50%);
  background:#333;color:#fff;padding:3px 8px;border-radius:5px;
  font-size:11px;white-space:nowrap;opacity:0;pointer-events:none;transition:.1s;z-index:999;
}
.ltool:hover .tip{opacity:1}

/* Canvas */
#gjs{flex:1;min-width:0;overflow:hidden;background:#2c2c2e}
#ed-right{min-width:256px;position:relative;z-index:2}

/* Right panel */
#ed-right{
  width:256px;background:#1d1d1f;border-left:1px solid #333;
  display:flex;flex-direction:column;flex-shrink:0;overflow:hidden;
}
.rtabs{display:flex;border-bottom:1px solid #2c2c2e;flex-shrink:0}
.rtab{
  flex:1;padding:9px 4px;text-align:center;font-size:11px;font-weight:500;
  color:#86868b;background:none;border:none;cursor:pointer;
  border-bottom:2px solid transparent;transition:.15s;
}
.rtab.on{color:#fff;border-bottom-color:#0071e3}
.rpanel{flex:1;overflow-y:auto;display:none}
.rpanel.on{display:block}

/* GrapesJS tweaks */
.gjs-editor,.gjs-editor-cont{height:100%!important}
.gjs-cv-canvas{background:#f0f0f0!important}
.gjs-toolbar{background:#0071e3!important;border-radius:6px!important}
.gjs-toolbar-item:hover{background:rgba(255,255,255,.2)!important}
.gjs-selected{outline:2px solid #0071e3!important;outline-offset:1px!important}
.gjs-hovered{outline:1px dashed #0071e3!important;outline-offset:1px!important}
/* Style manager dark */
.gjs-sm-sector-title,.gjs-sm-title,.gjs-sm-field,.gjs-sm-select,.gjs-sm-input{background:#2c2c2e!important;color:#ccc!important}
.gjs-sm-sector-title{padding:8px 10px!important;font-size:11px!important;text-transform:uppercase!important;letter-spacing:.05em!important;color:#86868b!important}
.gjs-sm-property{border-bottom:1px solid #333!important}
.gjs-pn-panel,.gjs-block-categories,.gjs-block-category{background:#1d1d1f!important;color:#ccc!important}
.gjs-block{border-color:#333!important;background:#2c2c2e!important;color:#ccc!important}
.gjs-block:hover{border-color:#0071e3!important;color:#fff!important}
.gjs-blocks-c{padding:6px!important}
.gjs-block-label{font-size:11px!important}
.gjs-layer,.gjs-layer-title{background:#1d1d1f!important;color:#ccc!important;border-color:#333!important}
.gjs-layer.gjs-selected{background:#2c2c2e!important}
.gjs-field,.gjs-input-unit{background:#2c2c2e!important;color:#ccc!important;border-color:#444!important}
.gjs-clm-tag{background:#2c2c2e!important;color:#ccc!important}
.gjs-trt-trait{border-color:#333!important}
/* hide default toolbar */
.gjs-pn-panels{display:none!important}
#gjs .gjs-frame-wrapper{padding:12px!important}
/* Custom toolbar items */
.gjs-toolbar-item svg{vertical-align:middle}
/* Comp info bar */
#comp-info{
  padding:5px 8px;font-size:11px;font-family:monospace;
  color:#555;background:#1d1d1f;border-bottom:1px solid #333;
  min-height:22px;line-height:1.4;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;
}
/* Quick-action buttons in left bar */
.ltool-dup svg{stroke:#56c0f2}
.ltool-dup:hover{background:#0d2a38!important}

/* Loading */
#ed-loading{
  position:fixed;inset:50px 0 0 0;background:#1a1a1a;z-index:8888;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:14px;color:#86868b;font-size:14px;
}
.spin{width:32px;height:32px;border:3px solid #333;border-top-color:#0071e3;border-radius:50%;animation:sp .7s linear infinite}
@keyframes sp{to{transform:rotate(360deg)}}

/* Toast */
#toast{
  position:fixed;bottom:20px;left:50%;transform:translateX(-50%) translateY(60px);opacity:0;
  background:#1d1d1f;color:#fff;padding:9px 18px;border-radius:9px;font-size:13px;font-weight:500;
  z-index:99999;transition:.2s;box-shadow:0 4px 18px rgba(0,0,0,.4);
}
#toast.show{transform:translateX(-50%) translateY(0);opacity:1}
#toast.ok{border-left:3px solid #28a745}
#toast.err{border-left:3px solid #c0392b}

/* ── Code Editor Modal ──────────────────── */
#code-modal{
  position:fixed;inset:0;background:rgba(0,0,0,.72);z-index:99998;
  display:none;align-items:stretch;justify-content:center;padding:12px;
}
#code-modal.open{display:flex}
#code-box{
  background:#1d1d1f;border-radius:12px;display:flex;flex-direction:column;
  width:100%;max-width:980px;overflow:hidden;border:1px solid #333;
}
#code-tabs{display:flex;border-bottom:1px solid #2c2c2e;flex-shrink:0}
.ctab{
  padding:10px 20px;font-size:13px;font-weight:600;cursor:pointer;
  background:none;border:none;color:#86868b;border-bottom:2px solid transparent;
  transition:.15s;font-family:inherit;
}
.ctab.on{color:#fff;border-bottom-color:#0071e3}
#code-ta{
  flex:1;background:#111;color:#e8e8e8;border:none;outline:none;
  font-family:'SF Mono',Menlo,Monaco,'Courier New',monospace;font-size:13px;
  line-height:1.6;padding:16px;resize:none;tab-size:2;
}
#code-foot{
  display:flex;align-items:center;gap:8px;padding:10px 14px;
  border-top:1px solid #2c2c2e;flex-shrink:0;background:#1d1d1f;
}
#code-foot span{flex:1;font-size:11px;color:#555}
.cbtn{
  padding:7px 16px;border-radius:7px;border:none;font-size:13px;
  font-weight:600;cursor:pointer;font-family:inherit;transition:.15s;
}
.cbtn-cancel{background:#2c2c2e;color:#ccc}.cbtn-cancel:hover{background:#3a3a3c}
.cbtn-apply{background:#0071e3;color:#fff}.cbtn-apply:hover{background:#0077ed}

/* ── Global CSS Modal ───────────────────── */
#global-css-modal{
  position:fixed;inset:0;background:rgba(0,0,0,.72);z-index:99998;
  display:none;align-items:center;justify-content:center;padding:12px;
}
#global-css-modal.open{display:flex}
#gcss-box{
  background:#1d1d1f;border-radius:12px;display:flex;flex-direction:column;
  width:100%;max-width:760px;max-height:80vh;overflow:hidden;border:1px solid #333;
}
#gcss-head{
  display:flex;align-items:center;gap:10px;padding:12px 18px;
  border-bottom:1px solid #2c2c2e;flex-shrink:0;
}
#gcss-ta{
  flex:1;background:#111;color:#e8e8e8;border:none;outline:none;
  font-family:'SF Mono',Menlo,Monaco,'Courier New',monospace;font-size:13px;
  line-height:1.6;padding:16px;resize:none;tab-size:2;min-height:280px;
}
#gcss-foot{
  display:flex;align-items:center;gap:8px;padding:10px 14px;
  border-top:1px solid #2c2c2e;flex-shrink:0;background:#1d1d1f;
}

/* ── Abs drag mode indicator ─────────────── */
#abs-badge{
  display:none;position:fixed;top:56px;left:50%;transform:translateX(-50%);
  background:#ff9f0a;color:#000;font-size:11px;font-weight:700;
  padding:3px 12px;border-radius:20px;z-index:9990;letter-spacing:.02em;
}
#abs-badge.on{display:block}
</style>
</head>
<body>

<!-- TOP BAR -->
<div id="ed-bar">
  <a class="back" href="/admin">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
    Admin
  </a>
  <div class="sep"></div>
  <span style="color:#86868b;font-size:12px;flex-shrink:0">Página:</span>
  <select id="psel" onchange="loadPage(this.value)">
    <optgroup label="Páginas principales">
      <option value="home">Portada</option>
      <option value="catalog">Catálogo</option>
    </optgroup>
    <optgroup label="Categorías">
      <% (categories||[]).forEach(c=>{ %>
      <option value="category-<%=c.slug%>"><%=c.name%></option>
      <% }) %>
    </optgroup>
    <optgroup label="Productos">
      <% (typeof products!=='undefined'?products:[]).forEach(p=>{ %>
      <option value="product-<%=p.slug%>"><%=p.name%></option>
      <% }) %>
    </optgroup>
  </select>
  <div class="sep"></div>
  <div class="dev-grp">
    <button class="dev-btn on" id="d-desktop" onclick="setDev('desktop')" title="Escritorio">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
    </button>
    <button class="dev-btn" id="d-tablet" onclick="setDev('tablet')" title="Tablet">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
    </button>
    <button class="dev-btn" id="d-mobile" onclick="setDev('mobile')" title="Móvil">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
    </button>
  </div>
  <div class="spacer"></div>
  <button class="tbtn tbtn-ghost" onclick="ed?.UndoManager?.undo()" title="Deshacer (Cmd+Z)">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 14 4 9 9 4"/><path d="M20 20v-7a4 4 0 0 0-4-4H4"/></svg>
  </button>
  <button class="tbtn tbtn-ghost" onclick="ed?.UndoManager?.redo()" title="Rehacer (Cmd+Shift+Z)">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 14 20 9 15 4"/><path d="M4 20v-7a4 4 0 0 1 4-4h12"/></svg>
  </button>
  <button class="tbtn tbtn-ghost" id="btn-code" onclick="openCodeEditor()" title="Editor de código HTML/CSS">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
    Código
  </button>
  <button class="tbtn tbtn-ghost" id="btn-global-css" onclick="openGlobalCss()" title="CSS Global — aplica a todas las páginas simultáneamente">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
    Global
  </button>
  <button class="tbtn tbtn-ghost" id="btn-abs" onclick="toggleAbsMode()" title="Modo posición libre (arrastra a cualquier lugar)">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 9l-3 3 3 3M9 5l3-3 3 3M15 19l-3 3-3-3M19 9l3 3-3 3M2 12h20M12 2v20"/></svg>
    Libre
  </button>
  <button class="tbtn tbtn-ghost" id="btn-prev" onclick="togglePreview()">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
    Vista previa
  </button>
  <button class="tbtn tbtn-ghost" id="btn-view" onclick="openInStore()" title="Ver página en la tienda">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
    Ver tienda
  </button>
  <button class="tbtn" id="btn-deploy" onclick="deployToGodaddy()" title="Exportar y publicar en GoDaddy vía FTP" style="background:#005c9e;color:#fff;flex-shrink:0">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
    Publicar GoDaddy
  </button>
  <button class="tbtn tbtn-ghost" id="btn-save-all" onclick="saveAll()" title="Actualiza datos (precios, categorías) en todas las páginas sin borrar tus diseños">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
    Actualizar datos
  </button>
  <button class="tbtn tbtn-green" id="btn-save" onclick="saveDesign()">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
    Guardar
  </button>
</div>

<!-- MAIN -->
<div id="ed-main">

  <!-- Left toolbar -->
  <div id="ed-left">
    <button class="ltool on" id="lt-style" onclick="showPanel('style')" title="Estilos">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
      <span class="tip">Estilos</span>
    </button>
    <button class="ltool" id="lt-blocks" onclick="showPanel('blocks')" title="Bloques">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
      <span class="tip">Bloques</span>
    </button>
    <button class="ltool" id="lt-layers" onclick="showPanel('layers')" title="Capas">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
      <span class="tip">Capas</span>
    </button>
    <button class="ltool" id="lt-traits" onclick="showPanel('traits')" title="Propiedades">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="12" y1="18" x2="20" y2="18"/><circle cx="2" cy="6" r="1" fill="currentColor"/><circle cx="4" cy="12" r="1" fill="currentColor"/><circle cx="6" cy="18" r="1" fill="currentColor"/></svg>
      <span class="tip">Propiedades</span>
    </button>
    <div style="flex:1"></div>
    <button class="ltool ltool-dup" onclick="dupSelected()" title="Duplicar seleccionado">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
      <span class="tip">Duplicar</span>
    </button>
    <button class="ltool ltool-del" onclick="delSelected()" title="Eliminar seleccionado">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
      <span class="tip">Eliminar</span>
    </button>
  </div>

  <!-- GrapesJS canvas -->
  <div id="gjs"></div>

  <!-- Right panel -->
  <div id="ed-right">
    <div class="rtabs">
      <button class="rtab on" onclick="showPanel('style')">Estilo</button>
      <button class="rtab" onclick="showPanel('blocks')">Bloques</button>
      <button class="rtab" onclick="showPanel('layers')">Capas</button>
      <button class="rtab" onclick="showPanel('traits')">Props</button>
    </div>
    <div id="rp-style"  class="rpanel on">
      <div id="comp-info">Selecciona un elemento para editar</div>
      <div id="sel-wrap" style="padding:4px 8px;border-bottom:1px solid #333;min-height:28px"></div>
      <div id="sm-wrap"></div>
    </div>
    <div id="rp-blocks" class="rpanel"><div id="bm-wrap"></div></div>
    <div id="rp-layers" class="rpanel"><div id="lm-wrap"></div></div>
    <div id="rp-traits" class="rpanel"><div id="tm-wrap"></div></div>
  </div>

</div>

<!-- Loading -->
<div id="ed-loading">
  <div class="spin"></div>
  <span id="ed-msg">Cargando página...</span>
</div>

<!-- Toast -->
<div id="toast"></div>

<!-- Abs mode badge -->
<div id="abs-badge">✦ POSICIÓN LIBRE</div>

<!-- Code Editor Modal -->
<div id="code-modal">
  <div id="code-box">
    <div id="code-tabs">
      <button class="ctab on" id="ctab-html" onclick="switchCodeTab('html')">HTML</button>
      <button class="ctab"    id="ctab-css"  onclick="switchCodeTab('css')">CSS</button>
    </div>
    <textarea id="code-ta" spellcheck="false" autocomplete="off" autocorrect="off" autocapitalize="off"></textarea>
    <div id="code-foot">
      <span id="code-hint">Edita el HTML o CSS y presiona Aplicar</span>
      <button class="cbtn cbtn-cancel" onclick="closeCodeEditor()">Cancelar</button>
      <button class="cbtn cbtn-apply"  onclick="applyCode()">Aplicar ✓</button>
    </div>
  </div>
</div>

<!-- Global CSS Modal -->
<div id="global-css-modal">
  <div id="gcss-box">
    <div id="gcss-head">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0071e3" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      <span style="font-size:13px;font-weight:600;color:#fff">CSS Global</span>
      <span style="font-size:12px;color:#555">— Aplica en todas las páginas del sitio automáticamente</span>
    </div>
    <textarea id="gcss-ta" spellcheck="false" autocomplete="off" placeholder="/* Ejemplo: cambiar el tamaño del logo en todo el sitio */&#10;.ms-logo img { width: 120px !important; }&#10;&#10;/* Cambiar fuente global */&#10;body { font-family: 'Georgia', serif; }"></textarea>
    <div id="gcss-foot">
      <span style="flex:1;font-size:11px;color:#555">El CSS se inyecta en el &lt;head&gt; de cada página al guardar. Vacío = sin CSS global.</span>
