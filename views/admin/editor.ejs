// ── Panel switcher ────────────────────────────────────────────────────────
function showPanel(name) {
  document.querySelectorAll('.rpanel').forEach(p => p.classList.remove('on'));
  document.querySelectorAll('.rtab').forEach(t => t.classList.remove('on'));
  document.querySelectorAll('.ltool[id^="lt-"]').forEach(b => b.classList.remove('on'));
  const rp = document.getElementById('rp-' + name);
  if (rp) rp.classList.add('on');
  // highlight matching left tool
  const lt = document.getElementById('lt-' + name);
  if (lt) lt.classList.add('on');
  // highlight tab
  const tabs = document.querySelectorAll('.rtab');
  const map = { style:0, blocks:1, layers:2, traits:3 };
  if (map[name] !== undefined && tabs[map[name]]) tabs[map[name]].classList.add('on');
}

