# ── Dependencias ────────────────────────────────
node_modules/

# ── Variables de entorno (NUNCA subir) ──────────
.env
.env.local
.env.production

# ── Credenciales Firebase (NUNCA subir) ─────────
serviceAccountKey.json
*serviceAccount*.json
firebase-adminsdk*.json

# ── Certificados SSL (NUNCA subir) ──────────────
ssl/
*.pem
*.key
*.crt
*.p12
*.pfx

# ── Archivos subidos por usuarios ───────────────
public/uploads/*
!public/uploads/.gitkeep

# JS y CSS compilados — se incluyen en el repo para deploy

# ── Logs ─────────────────────────────────────────
*.log
logs/
temp_uploads/

# ── Sistema operativo ─────────────────────────────
.DS_Store
Thumbs.db
__MACOSX/

# ── IDEs ──────────────────────────────────────────
.vscode/
.idea/
*.swp

# ── Base de datos local (contiene datos reales) ──
macstore.db
macstore.db-shm
macstore.db-wal
session-archives/

# ── Exportaciones estáticas ───────────────────────
exports/
